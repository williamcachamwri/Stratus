# Stratus storage provider configuration.
# Copy this file to shared/storage.local.config for real local values.
# Secrets in *.local.config are ignored by git.

# Amazon S3 / S3-compatible defaults used to prefill account setup.
STRATUS_S3_REGION=us-east-1
STRATUS_S3_ENDPOINT_URL=
STRATUS_S3_BUCKET=
STRATUS_S3_ACCESS_KEY_ID=
STRATUS_S3_SECRET_ACCESS_KEY=
STRATUS_S3_SESSION_TOKEN=
STRATUS_S3_USE_PATH_STYLE_URL=false
STRATUS_S3_USE_TRANSFER_ACCELERATION=false

STRATUS_WASABI_REGION=us-east-1
STRATUS_WASABI_ENDPOINT_URL=https://s3.us-east-1.wasabisys.com
STRATUS_WASABI_BUCKET=
STRATUS_WASABI_ACCESS_KEY_ID=
STRATUS_WASABI_SECRET_ACCESS_KEY=

STRATUS_BACKBLAZE_B2_REGION=us-west-004
STRATUS_BACKBLAZE_B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
STRATUS_BACKBLAZE_B2_BUCKET=
STRATUS_BACKBLAZE_B2_ACCESS_KEY_ID=
STRATUS_BACKBLAZE_B2_SECRET_ACCESS_KEY=

STRATUS_CLOUDFLARE_R2_ACCOUNT_ID=
STRATUS_CLOUDFLARE_R2_ENDPOINT_URL=
STRATUS_CLOUDFLARE_R2_BUCKET=
STRATUS_CLOUDFLARE_R2_ACCESS_KEY_ID=
STRATUS_CLOUDFLARE_R2_SECRET_ACCESS_KEY=
STRATUS_CLOUDFLARE_R2_REGION=auto

# Server-style providers.
STRATUS_SFTP_HOST=
STRATUS_SFTP_PORT=22
STRATUS_SFTP_USERNAME=
STRATUS_SFTP_PASSWORD=

STRATUS_WEBDAV_BASE_URL=
STRATUS_WEBDAV_USERNAME=
STRATUS_WEBDAV_PASSWORD=

STRATUS_FTP_HOST=
STRATUS_FTP_PORT=21
STRATUS_FTP_BASE_PATH=/
STRATUS_FTP_USERNAME=
STRATUS_FTP_PASSWORD=
STRATUS_FTP_USE_TLS=false
