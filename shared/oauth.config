# Stratus OAuth client configuration.
# Copy this file to shared/oauth.local.config for local secrets.
# Environment variables with the same names override values from this file.
# Never commit real client secrets; shared/*.local.config is gitignored.

STRATUS_GDRIVE_CLIENT_ID=
STRATUS_GDRIVE_CLIENT_SECRET=
STRATUS_GDRIVE_REDIRECT_URI=com.stratus.cloudmanager:/oauth2callback
STRATUS_GDRIVE_SCOPES=https://www.googleapis.com/auth/drive

STRATUS_DROPBOX_CLIENT_ID=
STRATUS_DROPBOX_CLIENT_SECRET=
STRATUS_DROPBOX_REDIRECT_URI=com.stratus.cloudmanager:/dropbox/callback
STRATUS_DROPBOX_SCOPES=files.content.write files.content.read account_info.read

STRATUS_ONEDRIVE_CLIENT_ID=
STRATUS_ONEDRIVE_CLIENT_SECRET=
STRATUS_ONEDRIVE_REDIRECT_URI=com.stratus.cloudmanager://auth/onedrive
STRATUS_ONEDRIVE_SCOPES=Files.ReadWrite.All offline_access User.Read

STRATUS_BOX_CLIENT_ID=
STRATUS_BOX_CLIENT_SECRET=
STRATUS_BOX_REDIRECT_URI=stratus://oauth/box
STRATUS_BOX_SCOPES=root_readwrite manage_webhooks
